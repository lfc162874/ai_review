# AI Review Server 环境变量配置

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/ai_review?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# AI Model (OpenAI Compatible)
AI_PROVIDER=openai
AI_API_KEY=your-api-key
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT=30000

# Object Storage (MinIO/S3)
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ai-review
STORAGE_USE_SSL=false
